# Email Configuration
# Replace these values with your SMTP server details
# For Gmail, use app-specific password and smtp.gmail.com
# Configure for: head.gmtconsulting@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=head.gmtconsulting@gmail.com
SMTP_PASS=your-gmail-app-password

# Email address used as the sender (use your Gmail address)
SMTP_FROM=head.gmtconsulting@gmail.com

# Receiving email for contact form submissions
CONTACT_RECEIVER_EMAIL=head.gmtconsulting@gmail.com
